{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "plan": "python3",
      "env": {
        "FLASK_APP": "main:app"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyAmount": 10,
    "healthcheckPath": "/health",
    "port": 8000
  }
}